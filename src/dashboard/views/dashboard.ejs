<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Control Panel · Turbo Gravity</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body>

  <!-- Sidebar Overlay (mobile) -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <div class="app-layout">
    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-brand">
          <div class="brand-icon">🚀</div>
          <div class="brand-text">
            <h2>Turbo Gravity</h2>
            <span>Control Panel</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">
          <div class="nav-label">Management</div>
          <button class="nav-item active" onclick="switchTab(event, 'tab-status')" id="nav-status">
            <span class="nav-icon">⚡</span> Bot Status
          </button>
          <button class="nav-item" onclick="switchTab(event, 'tab-profile')" id="nav-profile">
            <span class="nav-icon">🎨</span> Bot Profile
          </button>
          <button class="nav-item" onclick="switchTab(event, 'tab-presence')" id="nav-presence">
            <span class="nav-icon">📡</span> Presence
          </button>
          <button class="nav-item" onclick="switchTab(event, 'tab-settings')" id="nav-settings">
            <span class="nav-icon">⚙️</span> Settings
          </button>
        </div>

        <div class="nav-section">
          <div class="nav-label">Quick Links</div>
          <% if (guild) { %>
          <a class="nav-item" href="/selector">
            <span class="nav-icon">◀</span> All Servers
          </a>
          <% } %>
          <a class="nav-item" href="/control/invite" target="_blank">
            <span class="nav-icon">🔗</span> Invite Bot
          </a>
          <a class="nav-item" href="/logout">
            <span class="nav-icon">🚪</span> Logout
          </a>
        </div>
      </nav>

      <div class="sidebar-footer">
        <div class="user-badge">
          <div class="user-avatar-sm">
            <% if (user.avatar) { %>
              <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="Avatar" />
            <% } else { %>
              <%= user.username.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div class="user-badge-info">
            <div class="user-badge-name"><%= user.username %></div>
            <div class="user-badge-role">Administrator</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- ── Main Content ── -->
    <div class="main-content">
      <!-- Top Bar -->
      <header class="topbar">
        <div class="topbar-left">
          <button class="hamburger" id="hamburgerBtn" onclick="openSidebar()" aria-label="Menu">☰</button>
          <div class="breadcrumb">
            <% if (guild) { %>
              <a href="/selector">Servers</a>
              <span>/</span>
              <span><%= guild.name %></span>
            <% } else { %>
              <span>Dashboard</span>
            <% } %>
          </div>
        </div>
        <div class="topbar-right">
          <button class="theme-toggle" id="themeToggle" title="Toggle dark/light mode">🌙</button>
        </div>
      </header>

      <!-- Page Content -->
      <main class="page">
        <!-- Status Strip -->
        <div class="status-strip">
          <div class="status-indicator">
            <div class="pulse-dot <%= botStatus !== 'online' ? 'offline' : '' %>"></div>
            <strong>Bot is <%= botStatus.toUpperCase() %></strong>
          </div>
          <div class="status-sep"></div>
          <span class="text-muted text-sm">
            <% if (guild) { %>
              Managing <strong style="color:var(--text)"><%= guild.name %></strong>
            <% } else { %>
              Global dashboard
            <% } %>
          </span>
          <% if (botStatus === 'online') { %>
            <span class="badge badge-success ml-auto">● Live</span>
          <% } else { %>
            <span class="badge badge-muted ml-auto">● Offline</span>
          <% } %>
        </div>

        <!-- ── Tab: Bot Status ── -->
        <div class="tab-panel active" id="tab-status">
          <div class="page-header">
            <h1 class="page-title">Bot Status</h1>
            <p class="page-subtitle">Monitor and control your Discord bot</p>
          </div>

          <div class="grid grid-2">
            <!-- Status Card -->
            <div class="card">
              <div class="card-icon blue">⚡</div>
              <div class="card-label">Current State</div>
              <div class="card-title">Connection Status</div>
              <div style="margin: 20px 0;">
                <span class="badge <%= botStatus === 'online' ? 'badge-success' : 'badge-muted' %>" style="font-size:14px; padding:8px 16px; border-radius:var(--radius-sm);">
                  <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:currentColor;margin-right:4px;"></span>
                  <%= botStatus.toUpperCase() %>
                </span>
              </div>
              <p class="form-hint">
                <%= botStatus === 'online'
                  ? '✅ Bot is connected to Discord and actively serving.'
                  : '⚠️ Bot is disconnected. Use Start below to bring it online.' %>
              </p>
            </div>

            <!-- Control Card -->
            <div class="card">
              <div class="card-icon green">🎛️</div>
              <div class="card-label">Quick Actions</div>
              <div class="card-title" style="margin-bottom:20px">Bot Controls</div>
              <div class="actions-row">
                <form method="POST" action="/control/start">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-success" type="submit">▶ Start</button>
                </form>
                <form method="POST" action="/control/stop">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-danger" type="submit">■ Stop</button>
                </form>
                <form method="POST" action="/control/restart">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-primary" type="submit">↺ Restart</button>
                </form>
              </div>
              <p class="form-hint" style="margin-top:14px">
                Changes to settings often require a restart to take effect.
              </p>
            </div>
          </div>

          <!-- Invite Link -->
          <div class="card mt-6">
            <div class="card-label">Invite</div>
            <div class="card-title" style="margin-bottom:12px">Bot Invite Link</div>
            <p class="form-hint" style="margin-bottom:12px">Share this link to invite the bot to other servers:</p>
            <div class="code-block"><%= inviteLink %></div>
            <div class="actions-row" style="margin-top:14px">
              <a class="btn btn-primary" href="<%= inviteLink %>" target="_blank">🔗 Open Invite</a>
              <button class="btn btn-ghost" onclick="copyInvite()">📋 Copy Link</button>
            </div>
          </div>
        </div>

        <!-- ── Tab: Bot Profile ── -->
        <div class="tab-panel" id="tab-profile">
          <div class="page-header">
            <h1 class="page-title">Bot Profile</h1>
            <p class="page-subtitle">Customize your bot's identity on Discord</p>
          </div>

          <div class="card">
            <div class="card-icon purple">🎨</div>
            <div class="card-label">Identity</div>
            <div class="card-title" style="margin-bottom:20px">Profile Settings</div>

            <form class="form" method="POST" action="/control/profile">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="form-group">
                <label class="form-label">Bot Username</label>
                <input type="text" name="username" placeholder="Turbo Gravity" minlength="2" maxlength="32" />
                <p class="form-hint">2–32 characters. Leave blank to keep current name.</p>
              </div>

              <div class="form-group">
                <label class="form-label">Avatar URL</label>
                <input type="url" name="avatar" placeholder="https://example.com/avatar.png" />
                <p class="form-hint">Direct image link (PNG / JPG / GIF). Recommended: 1024×1024.</p>
              </div>

              <div class="form-group">
                <label class="form-label">Bio / About Me</label>
                <textarea name="bio" maxlength="190" placeholder="Powerful Discord bot serving {members} members!"></textarea>
                <p class="form-hint">Up to 190 characters. Supports dynamic variables (see below).</p>
              </div>

              <div class="info-box">
                <strong>🔮 Dynamic Variables</strong> — replace these in your bio with live data:
                <div class="variable-grid">
                  <div class="var-tag">{members} <span class="var-desc">members</span></div>
                  <div class="var-tag">{guilds} <span class="var-desc">servers</span></div>
                  <div class="var-tag">{users} <span class="var-desc">users</span></div>
                  <div class="var-tag">{botname} <span class="var-desc">bot name</span></div>
                  <div class="var-tag">{servername} <span class="var-desc">server</span></div>
                  <div class="var-tag">{timestamp} <span class="var-desc">time</span></div>
                </div>
              </div>

              <button class="btn btn-primary btn-lg" type="submit">💾 Save Profile</button>
            </form>
          </div>
        </div>

        <!-- ── Tab: Presence ── -->
        <div class="tab-panel" id="tab-presence">
          <div class="page-header">
            <h1 class="page-title">Presence</h1>
            <p class="page-subtitle">Set what your bot shows as its activity status</p>
          </div>

          <div class="card">
            <div class="card-icon blue">📡</div>
            <div class="card-label">Activity</div>
            <div class="card-title" style="margin-bottom:20px">Status & Activity</div>

            <form class="form" method="POST" action="/control/status">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="dual-grid">
                <div class="form-group">
                  <label class="form-label">Activity Type</label>
                  <select name="activityType">
                    <option value="0">🎮 Playing</option>
                    <option value="2">🎵 Listening to</option>
                    <option value="3">📺 Watching</option>
                    <option value="5">🏆 Competing in</option>
                  </select>
                </div>

                <div class="form-group">
                  <label class="form-label">Status Text</label>
                  <input type="text" name="statusText" placeholder="with your commands" required />
                </div>
              </div>

              <div class="info-box">
                <strong>🔮 Dynamic Variables</strong> — use in status text:
                <div class="variable-grid">
                  <div class="var-tag">{members} <span class="var-desc">members</span></div>
                  <div class="var-tag">{guilds} <span class="var-desc">servers</span></div>
                  <div class="var-tag">{users} <span class="var-desc">users</span></div>
                  <div class="var-tag">{botname} <span class="var-desc">bot name</span></div>
                  <div class="var-tag">{servername} <span class="var-desc">server</span></div>
                  <div class="var-tag">{prefix} <span class="var-desc">prefix /</span></div>
                  <div class="var-tag">{timestamp} <span class="var-desc">time</span></div>
                </div>
              </div>

              <button class="btn btn-primary" type="submit">💾 Save Presence</button>
            </form>
          </div>
        </div>

        <!-- ── Tab: Settings ── -->
        <div class="tab-panel" id="tab-settings">
          <div class="page-header">
            <h1 class="page-title">Settings</h1>
            <p class="page-subtitle">Configure bot behavior and connection settings</p>
          </div>

          <form class="form" method="POST" action="/control/config" id="settingsForm">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="grid grid-2">
              <!-- General -->
              <div class="card">
                <div class="card-icon gold">⚙️</div>
                <div class="card-label">General</div>
                <div class="card-title" style="margin-bottom:20px">Bot Behavior</div>

                <div class="form-group">
                  <label class="form-label">Command Scope</label>
                  <select name="commandScope">
                    <option value="guild" <%= config && config.commandScope === 'guild' ? 'selected' : '' %>>Guild (Instant)</option>
                    <option value="global" <%= config && config.commandScope === 'global' ? 'selected' : '' %>>Global (up to 1h cache)</option>
                  </select>
                  <p class="form-hint">Guild scope registers instantly; global scope caches for up to 1 hour.</p>
                </div>

                <div class="form-group">
                  <label class="form-label">Guild ID (Optional)</label>
                  <input type="text" name="guildId" value="<%= config ? config.guildId : '' %>" placeholder="Discord server ID" />
                  <p class="form-hint">For guild-scoped command registration only.</p>
                </div>

                <div class="form-group">
                  <label class="form-label">Invite Permissions</label>
                  <input type="text" name="invitePermissions" value="<%= config ? config.invitePermissions : '8' %>" />
                  <p class="form-hint">Permission integer for the invite link. <code style="font-family:var(--mono);color:var(--primary)">8</code> = Administrator.</p>
                </div>

                <div class="form-group">
                  <label class="checkbox-group">
                    <input type="checkbox" name="autoStart" <%= config && config.autoStart ? 'checked' : '' %> />
                    <span>Auto-start bot on dashboard launch</span>
                  </label>
                </div>
              </div>

              <!-- Credentials -->
              <div class="card">
                <div class="card-icon blue">🔑</div>
                <div class="card-label">Credentials</div>
                <div class="card-title" style="margin-bottom:20px">Bot Tokens</div>

                <div class="form-group">
                  <label class="form-label">Bot Token</label>
                  <input type="password" name="botToken" placeholder="Leave blank to keep current" autocomplete="off" />
                  <p class="form-hint">Only fill in to update. Your token is stored securely.</p>
                </div>

                <div class="form-group">
                  <label class="form-label">Client ID</label>
                  <input type="text" name="clientId" placeholder="Leave blank to keep current" />
                </div>

                <div class="form-group">
                  <label class="form-label">Client Secret</label>
                  <input type="password" name="clientSecret" placeholder="Leave blank to keep current" autocomplete="off" />
                </div>

                <div class="form-group">
                  <label class="form-label">OAuth Callback URL</label>
                  <input type="url" name="callbackUrl" placeholder="http://localhost:8080/auth/discord/callback" />
                </div>
              </div>
            </div>

            <div style="display:flex; justify-content:flex-end; margin-top:4px;">
              <button class="btn btn-primary btn-lg" type="submit">💾 Save Settings</button>
            </div>
          </form>
        </div>
      </main>
    </div><!-- /main-content -->
  </div><!-- /app-layout -->

  <script>
    // ── Tab switching ────────────────────────────────────────────────────────
    const tabMap = {
      'tab-status':   'nav-status',
      'tab-profile':  'nav-profile',
      'tab-presence': 'nav-presence',
      'tab-settings': 'nav-settings',
    };

    function switchTab(evt, tabId) {
      // Deactivate all panels + nav items
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

      // Activate chosen
      document.getElementById(tabId).classList.add('active');
      const navId = tabMap[tabId];
      if (navId) document.getElementById(navId).classList.add('active');

      // Close sidebar on mobile
      if (window.innerWidth < 900) closeSidebar();

      // Save to hash
      window.location.hash = tabId;
    }

    // Restore tab from URL hash
    (function() {
      const hash = window.location.hash.replace('#', '');
      if (hash && document.getElementById(hash)) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        document.getElementById(hash).classList.add('active');
        const navId = tabMap[hash];
        if (navId) document.getElementById(navId).classList.add('active');
      }
    })();

    // ── Sidebar ──────────────────────────────────────────────────────────────
    function openSidebar() {
      document.getElementById('sidebar').classList.add('open');
      document.getElementById('sidebarOverlay').classList.add('active');
    }

    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('active');
    }

    // ── Theme toggle ─────────────────────────────────────────────────────────
    (function() {
      const html = document.documentElement;
      const btn = document.getElementById('themeToggle');
      const saved = localStorage.getItem('tg-theme') || 'dark';
      if (saved === 'light') html.classList.add('light');
      btn.textContent = saved === 'light' ? '🌙' : '☀️';

      btn.addEventListener('click', () => {
        const isLight = html.classList.toggle('light');
        localStorage.setItem('tg-theme', isLight ? 'light' : 'dark');
        btn.textContent = isLight ? '🌙' : '☀️';
      });
    })();

    // ── Copy invite ──────────────────────────────────────────────────────────
    function copyInvite() {
      const link = '<%= inviteLink %>';
      navigator.clipboard.writeText(link).then(() => {
        const btn = event.target;
        btn.textContent = '✅ Copied!';
        setTimeout(() => btn.textContent = '📋 Copy Link', 2000);
      });
    }
  </script>
</body>
</html>
