<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Select Server · Turbo Gravity</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/public/styles.css" />
</head>
<body>
<div class="selector-wrapper">

  <!-- Top Bar -->
  <header class="selector-topbar">
    <div class="selector-brand" style="display:flex;align-items:center;gap:12px;">
      <div class="brand-icon" style="width:36px;height:36px;background:linear-gradient(135deg,var(--primary),#7c3aed);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 12px var(--primary-glow);">🚀</div>
      <div>
        <div style="font-size:16px;font-weight:700;letter-spacing:-0.3px;">Turbo Gravity</div>
        <div style="font-size:11px;color:var(--text-muted);">Dashboard</div>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:10px;">
      <% if (user) { %>
      <div style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:999px;">
        <div style="width:28px;height:28px;border-radius:50%;overflow:hidden;background:linear-gradient(135deg,var(--primary),#7c3aed);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;flex-shrink:0;">
          <% if (user.avatar) { %>
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" style="width:100%;height:100%;object-fit:cover;" />
          <% } else { %><%= user.username.charAt(0).toUpperCase() %><% } %>
        </div>
        <span style="font-size:13px;font-weight:600;"><%= user.username %></span>
      </div>
      <% } %>

      <span class="badge <%= botStatus === 'online' ? 'badge-success' : 'badge-muted' %>">
        ● Bot <%= botStatus.toUpperCase() %>
      </span>

      <button class="theme-toggle" id="themeToggle" title="Toggle theme">🌙</button>
      <a href="/logout" class="btn btn-ghost btn-sm">Logout</a>
    </div>
  </header>

  <!-- Content -->
  <div class="selector-content">
    <div class="selector-hero">
      <div style="font-size:48px;margin-bottom:12px;">🌐</div>
      <h1>Choose a Server</h1>
      <p>Select a Discord server you manage to configure and monitor</p>
    </div>

    <% if (user && user.displayedGuilds && user.displayedGuilds.length > 0) { %>
      <div class="guilds-grid">
        <% user.displayedGuilds.forEach(function(guild) { %>
        <div class="guild-card" onclick="window.location='/manage/<%= guild.id %>'">
          <div class="guild-banner" style="background:linear-gradient(135deg,
            hsl(<%= parseInt(guild.id.slice(-3), 16) % 360 %>, 60%, 30%),
            hsl(<%= (parseInt(guild.id.slice(-6,-3), 16) + 60) % 360 %>, 60%, 25%));">
          </div>
          <div class="guild-body">
            <div class="guild-avatar">
              <% if (guild.icon) { %>
                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=128" alt="<%= guild.name %>" />
              <% } else { %>
                <%= guild.name.split(' ').map(function(w){ return w[0]; }).join('').toUpperCase().slice(0,2) %>
              <% } %>
            </div>
            <div class="guild-name"><%= guild.name %></div>
            <div class="guild-meta">
              <% if (guild.member_count) { %>👥 <%= guild.member_count.toLocaleString() %> members<% } else { %>Discord Server<% } %>
            </div>
            <div class="guild-actions">
              <a href="/manage/<%= guild.id %>" class="btn btn-primary btn-sm" style="flex:1;" onclick="event.stopPropagation()">
                ⚙️ Manage
              </a>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

    <% } else { %>
      <div style="text-align:center;padding:60px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-xl);max-width:520px;margin:0 auto;">
        <div style="font-size:52px;margin-bottom:16px;">🔍</div>
        <h2 style="font-size:22px;font-weight:700;margin-bottom:8px;">No Servers Found</h2>
        <p style="font-size:15px;color:var(--text-muted);line-height:1.6;margin-bottom:24px;">
          You don't have "Manage Server" permissions on any Discord server where the bot is present.<br/>
          Make sure you're logged in with the correct Discord account.
        </p>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
          <a href="/control/invite" class="btn btn-primary">🔗 Invite Bot to Server</a>
          <a href="/logout" class="btn btn-ghost">🔄 Switch Account</a>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  (function() {
    const html = document.documentElement;
    const btn = document.getElementById('themeToggle');
    const saved = localStorage.getItem('tg-theme') || 'dark';
    if (saved === 'light') html.classList.add('light');
    btn.textContent = saved === 'light' ? '🌙' : '☀️';
    btn.addEventListener('click', () => {
      const isLight = html.classList.toggle('light');
      localStorage.setItem('tg-theme', isLight ? 'light' : 'dark');
      btn.textContent = isLight ? '🌙' : '☀️';
    });
  })();
</script>
</body>
</html>
